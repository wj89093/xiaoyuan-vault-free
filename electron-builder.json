{
  "appId": "com.xiaoyuan.vault",
  "productName": "晓园 Vault",
  "asar": true,
  "npmRebuild": false,
  "directories": {
    "buildResources": "resources",
    "output": "dist"
  },
  "files": [
    "out/**/*",
    "**/*.map",
    "!**/node_modules/{mermaid,@mermaid-js,tesseract.js,tesseract.js-core,pdfjs-dist,exceljs,xlsx,mammoth,docx-preview,pptx-preview,echarts,@antfu,@babel,lucide-react,@napi-rs,pdf-parse,cytoscape,cytoscape-fcose,react-dom,react-router-dom,d3,lodash,@types,katex,react-router,codepage,zrender,es-toolkit,zlibjs,underscore,lodash-es}/**"
  ],
  "asarUnpack": [
    "**/*.node",
    "whisper/**"
  ],
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["arm64"]
      }
    ],
    "category": "public.app-category.productivity",
    "hardenedRuntime": false,
    "gatekeeperAssess": false,
    "identity": null
  },
  "afterPack": "scripts/after-pack.js",
  "win": {
    "target": [{"target": "nsis", "arch": ["x64"]}]
  },
  "linux": {
    "target": [{"target": "AppImage", "arch": ["x64"]}],
    "category": "Office"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true
  }
}
